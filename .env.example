# Site
NEXT_PUBLIC_SITE_DOMAIN=yoursite.dev

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<key>
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=<project-ref>

# GitHub Actions secrets only (not needed locally)
# SUPABASE_ACCESS_TOKEN=     from supabase.com → Account → Access Tokens
# SUPABASE_DB_PASSWORD=      from Supabase → Settings → Database → password

# Admin
ADMIN_USER_ID=
# your Supabase auth UUID — set after first login at /admin/login

# Cloudflare Turnstile (admin login form)
# get keys at dash.cloudflare.com → Turnstile → Add site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Local dev test keys (always pass, provided by Cloudflare):
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
